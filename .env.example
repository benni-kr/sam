# 1. Required for runtime connection to Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 2. Database Partitioning (The "Scope" Trick)
# SAM uses this scope to partition records within the exact same Supabase database.
# This prevents different environments from colliding or accidentally deleting real events.
#
# -> For the live Vercel production app:
# NEXT_PUBLIC_SAM_PLANNER_SCOPE=prod
#
# -> CRITICAL FOR LOCAL DEV: Change 'default' to your name (e.g., dev-paul, dev-miriam) 
# so your local tests do not overwrite or delete the production calendar data!
NEXT_PUBLIC_SAM_PLANNER_SCOPE=default
